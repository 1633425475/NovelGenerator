# API 基础地址
VITE_API_BASE_URL=/api

# 应用配置
VITE_APP_TITLE=小说AI创作平台
VITE_APP_DESCRIPTION=基于 Spring Boot AI 的小说生成工具，支持从大纲到视频的全流程创作
VITE_APP_VERSION=1.0.0

# 开发环境配置
VITE_DEBUG=true
VITE_DEV_SERVER_PORT=5173
VITE_DEV_SERVER_HOST=localhost

# 功能开关
VITE_FEATURE_AI_OUTLINE=true
VITE_FEATURE_AI_IMAGE=true
VITE_FEATURE_AI_AUDIO=true
VITE_FEATURE_AI_VIDEO=true
VITE_FEATURE_CHARACTER_MANAGEMENT=true
VITE_FEATURE_RELATION_GRAPH=true

# 第三方服务配置
VITE_ECHARTS_ENABLED=true
VITE_VIDEOJS_ENABLED=true

# 主题配置
VITE_THEME_PRIMARY_COLOR=#409EFF
VITE_THEME_SUCCESS_COLOR=#67C23A
VITE_THEME_WARNING_COLOR=#E6A23C
VITE_THEME_DANGER_COLOR=#F56C6C
VITE_THEME_INFO_COLOR=#909399

# 路由配置
VITE_ROUTER_MODE=history
VITE_ROUTER_BASE=/

# 存储配置
VITE_STORAGE_PREFIX=novel_ai_
VITE_STORAGE_TOKEN_KEY=token
VITE_STORAGE_USER_KEY=user

# 请求配置
VITE_REQUEST_TIMEOUT=30000
VITE_REQUEST_BASE_URL=/api
VITE_REQUEST_WITH_CREDENTIALS=true

# 图片上传配置
VITE_UPLOAD_MAX_SIZE=52428800 # 50MB
VITE_UPLOAD_ALLOWED_TYPES=image/jpeg,image/png,image/gif,image/webp

# 视频配置
VITE_VIDEO_MAX_DURATION=60 # 秒
VITE_VIDEO_MAX_SIZE=104857600 # 100MB

# 预览配置
VITE_PREVIEW_IMAGE_MAX_WIDTH=1920
VITE_PREVIEW_IMAGE_MAX_HEIGHT=1080