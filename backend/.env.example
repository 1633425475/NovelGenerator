# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_NAME=novel_ai
DB_USERNAME=root
DB_PASSWORD=your_password

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASE=0

# OpenAI API配置
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com
OPENAI_MODEL=gpt-4-turbo-preview

# JWT配置
JWT_SECRET=your_jwt_secret_key_change_in_production
JWT_EXPIRATION=86400000

# MinIO配置
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_DEFAULT=novel-ai

# ComfyUI配置
COMFYUI_BASE_URL=http://localhost:8188
COMFYUI_CLIENT_TIMEOUT=300000
COMFYUI_POLL_INTERVAL=5000

# Azure TTS配置
AZURE_TTS_KEY=your_azure_tts_key
AZURE_TTS_REGION=eastasia

# ElevenLabs配置
ELEVENLABS_API_KEY=your_elevenlabs_api_key

# 阿里云配置
ALIYUN_ACCESS_KEY=your_aliyun_access_key
ALIYUN_SECRET_KEY=your_aliyun_secret_key
ALIYUN_TTS_APPKEY=your_aliyun_tts_appkey

# 应用配置
SERVER_PORT=8088
SERVER_CONTEXT_PATH=/api

# 日志级别
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_COM_LAOJI=DEBUG

# 安全配置
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS